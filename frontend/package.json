{
  "name": "qr-menu-frontend",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "build": "vite build",
    "build:debug": "vite build && echo 'Current directory:' && pwd && echo 'Listing files:' && ls -la && echo 'Checking dist folder:' && ls -la dist || echo '❌ No dist folder!'",
    "dev": "vite --host",
    "lint": "eslint . --ext js,jsx,ts,tsx --fix",
    "preview": "vite preview --host",
    "type-check": "tsc --noEmit"
  },
  "dependencies": {
    "@types/qrcode.react": "^3.0.0",
    "qrcode.react": "^4.2.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-icons": "^5.5.0",
    "react-router-dom": "^7.13.1"
  },
  "devDependencies": {
    "@eslint/js": "^9.13.0",
    "@types/node": "^25.3.3",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.3",
    "eslint": "^9.13.0",
    "eslint-plugin-react-hooks": "^5.0.0",
    "eslint-plugin-react-refresh": "^0.4.14",
    "globals": "^15.11.0",
    "typescript": "~5.6.2",
    "typescript-eslint": "^8.11.0",
    "vite": "^5.4.10",
    "vite-plugin-pwa": "^1.2.0"
  }
}
