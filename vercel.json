{
  "builds": [
    {
      "src": "package.json",
      "use": "@vercel/static-build",
      "config": {
        "rootDirectory": "frontend",
        "distDir": "dist",
        "buildCommand": "npm install && npm run build",
        "zeroConfig": true
      }
    },
    {
      "src": "api/**/*.js",
      "use": "@vercel/node"
    }
  ],
  "routes": [
    { "src": "/api/health", "dest": "/api/health.js" },
    { "src": "/api/categories/?$", "dest": "/api/categories/index.js" },
    { "src": "/api/categories/([^/]+)", "dest": "/api/categories/[id].js" },
    { "src": "/api/menu/?$", "dest": "/api/menu/index.js" },
    { "src": "/api/menu/([^/]+)", "dest": "/api/menu/[id].js" },
    { "handle": "filesystem" },
    { "src": "/(.*)", "dest": "/frontend/dist/index.html" }
  ]
}