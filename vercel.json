      "use": "@vercel/static-build",
      "config": {
        "rootDirectory": "C:/Users/jorge/Music/Desktop/PWA-QR-MENU/frontend",
        "distDir": "C:/Users/jorge/Music/Desktop/PWA-QR-MENU/frontend/dist",
        "buildCommand": "npm ci && npm run build"
      }
    },
    {
      "src": "C:/Users/jorge/Music/Desktop/PWA-QR-MENU/api/**/*.js",
      "use": "@vercel/node"
    }
